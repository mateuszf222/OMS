{
  "name": "oms-contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Kontrakty OMS (OpenAPI 3.1 + AsyncAPI 3.0) oraz ruleset Spectral egzekwujący API-*/EVT-*.",
  "scripts": {
    "lint": "spectral lint \"openapi/*.v1.yaml\" \"events/*.v1.yaml\" --ruleset .spectral.yaml --fail-severity error",
    "lint:strict": "spectral lint \"openapi/*.v1.yaml\" \"events/*.v1.yaml\" --ruleset .spectral.yaml --fail-severity warn"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.11.0"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.4.0",
    "@asyncapi/diff": "^0.5.0"
  }
}
